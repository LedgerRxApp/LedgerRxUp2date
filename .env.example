# ─────────────────────────────────────────────────────────────────────────────
# LedgerRx — Environment Variable Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Platform (auto-injected in Manus — do not edit) ──────────────────────────
DATABASE_URL=
JWT_SECRET=
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── QuickBooks Online OAuth 2.0 ───────────────────────────────────────────────
# Obtain from: https://developer.intuit.com → My Apps → [Your App] → Keys & OAuth
#
# 1. QBO_CLIENT_ID
#    The OAuth 2.0 Client ID for your Intuit app.
#    Found under: Keys & OAuth → Production Keys → Client ID
#                 Keys & OAuth → Sandbox Keys → Client ID
QBO_CLIENT_ID=

# 2. QBO_CLIENT_SECRET
#    The OAuth 2.0 Client Secret for your Intuit app.
#    Found under: Keys & OAuth → Production Keys → Client Secret
#                 Keys & OAuth → Sandbox Keys → Client Secret
#    Treat this as a password — never expose it to the browser.
QBO_CLIENT_SECRET=

# 3. QBO_REDIRECT_URI
#
#    EXACT URI TO REGISTER IN INTUIT:
#
#    Production / hosted:
#      https://<your-domain>/api/qbo/callback
#
#    Local development:
#      http://localhost:3000/api/qbo/callback
#
#    Where to register it in Intuit:
#      developer.intuit.com → My Apps → [Your App]
#      → Keys & OAuth → Redirect URIs → Add URI
#
#    The value here MUST match the registered URI character-for-character.
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback

# 4. QBO_ENVIRONMENT
#    "sandbox"    — use Intuit sandbox company (safe for testing)
#    "production" — use live QuickBooks company data
#    Start with "sandbox" until you have verified the full OAuth flow.
QBO_ENVIRONMENT=sandbox

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
